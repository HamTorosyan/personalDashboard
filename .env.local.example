# Generate with: npx auth secret
AUTH_SECRET=<your-auth-secret>

# Microsoft Azure AD App Registration
# Account types: "Multitenant + personal Microsoft accounts" (tenant=common)
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
# Required permissions: Calendars.Read, User.Read, offline_access
MICROSOFT_CLIENT_ID=<your-azure-app-client-id>
MICROSOFT_CLIENT_SECRET=<your-azure-app-client-secret>

# Zoom OAuth App (User-managed, development mode)
# Redirect URL: http://localhost:3000/api/auth/callback/zoom
# Required scope: meeting:read
ZOOM_CLIENT_ID=<your-zoom-client-id>
ZOOM_CLIENT_SECRET=<your-zoom-client-secret>

# App URL (required by next-auth for redirect URI construction)
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
